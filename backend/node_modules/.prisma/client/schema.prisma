generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int                @id @default(autoincrement())
  email       String             @unique
  pushToken   String?
  inventory   VirtualInventory[]
  withdrawals WithdrawalOrder[]
}

model Product {
  id                 Int                @id @default(autoincrement())
  name               String
  sku                String             @unique
  physicalStock      Int                @default(0)
  virtualInventories VirtualInventory[]
}

model VirtualInventory {
  userId        Int
  productId     Int
  quantityOwned Int     @default(0)
  user          User    @relation(fields: [userId], references: [id])
  product       Product @relation(fields: [productId], references: [id])

  @@id([userId, productId])
}

model WithdrawalOrder {
  id     Int    @id @default(autoincrement())
  userId Int
  status String @default("PENDING_PAYMENT")
  user   User   @relation(fields: [userId], references: [id])
}
